#!/usr/bin/env python3
"""familiar — включение/выключение kitty-оверлеев в конфиге kitty.

Ставит выбранные китены (и опционально настройки терминала) в
kitty.conf, не заставляя пользователя руками править абсолютные
пути. kitty требует абсолютный путь к kitten (относительный
резолвит от ~/.config/kitty, а не от файла с `map`) — поэтому
familiar подставляет реальный путь установки сам, находя его от
собственного расположения. Работает и из клона репозитория, и из
brew-префикса.

Правки идут в размеченный блок между маркерами, поэтому `disable`
снимает ровно то, что добавил familiar, не трогая остальной
kitty.conf. Перед первой правкой снимается резервная копия
kitty.conf — для отката терминал-режима, который может
переопределить чужие настройки.
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import sys
import tempfile
import urllib.request


MARKER_BEGIN = "# >>> familiar >>> (managed by `familiar enable` — do not edit)"
MARKER_END = "# <<< familiar <<<"

GENERATED_CONF = "familiar.conf"
BACKUP_SUFFIX = ".familiar.bak"

# Порядок ключей канонический (session, review, log) —
# render_generated_conf выводит киты именно в нём, независимо от
# порядка аргументов. clipboard=True — внутри review/log копирование
# (cmd+c/cmd+shift+c) и поиск по файлу (cmd+f) должны доходить до
# kitten, поэтому глобальные маппинги снимаем, пока оверлей в фокусе.
# find — клавиши режима Find in Files: работают ТОЛЬКО в фокусе кита
# (снимаем возможный глобальный маппинг, глобального своего не ставим —
# снаружи оверлея поиск не открывается).
KITTENS = {
    "session": {"key": "s", "ru": "ы", "file": "session.py",
                "clipboard": False, "desc": "Claude Code sessions"},
    "review": {"key": "r", "ru": "к", "file": "review.py",
               "clipboard": True, "desc": "uncommitted git changes",
               "find": ("f", "а")},
    "log": {"key": "l", "ru": "д", "file": "log.py",
            "clipboard": True, "desc": "git history browser"},
}


def app_root() -> str:
    # FAMILIAR_ROOT задаёт brew-обёртка стабильным opt-путём
    # (…/opt/familiar/libexec): он переживает `brew upgrade`, тогда
    # как realpath схлопнул бы симлинк до версионного
    # …/Cellar/familiar/<ver>/… — и запечённые в конфиг пути
    # ломались бы при обновлении.
    env = os.environ.get("FAMILIAR_ROOT")
    if env:
        return env
    # Клон: <root>/bin/familiar → <root>. Папка клона стабильна,
    # realpath безопасен.
    return os.path.dirname(os.path.dirname(os.path.realpath(__file__)))


def plugins_dir() -> str:
    return os.path.join(app_root(), "plugins")


def config_source_dir() -> str:
    return os.path.join(app_root(), "config")


def installed_version() -> str:
    # Версия живёт в файле VERSION корня установки — единый источник
    # для CLI и китов (plugins/modules/update.py).
    try:
        with open(os.path.join(app_root(), "VERSION"), encoding="utf-8") as f:
            return f.read().strip() or "unknown"
    except OSError:
        return "unknown"


VERSION = installed_version()

TAGS_URL = "https://api.github.com/repos/DenoBY/familiar/tags?per_page=100"
UPDATE_ENV = "FAMILIAR_UPDATE_CHECK"


def parse_version(s: str) -> tuple[int, ...] | None:
    try:
        return tuple(int(p) for p in s.lstrip("v").split("."))
    except ValueError:
        return None


def latest_release(timeout: float = 2.0) -> str | None:
    # Дублирует запрос из modules/update.py сознательно: CLI —
    # автономный однофайловый скрипт и пакет китов не импортирует.
    # Релизы familiar — теги без GitHub Release, поэтому /tags;
    # порядок ответа не гарантирован — берём максимум по semver.
    try:
        with urllib.request.urlopen(TAGS_URL, timeout=timeout) as resp:
            tags = json.load(resp)
    except (OSError, ValueError):
        return None
    if not isinstance(tags, list):
        return None
    versions = [(v, t["name"].lstrip("v")) for t in tags
                if isinstance(t, dict) and isinstance(t.get("name"), str)
                and (v := parse_version(t["name"]))]
    return max(versions)[1] if versions else None


def kitty_config_dir() -> str:
    # Порядок как у самого kitty: KITTY_CONFIG_DIRECTORY →
    # XDG_CONFIG_HOME/kitty → ~/.config/kitty.
    env = os.environ.get("KITTY_CONFIG_DIRECTORY")
    if env:
        return os.path.expanduser(env)
    xdg = os.environ.get("XDG_CONFIG_HOME")
    if xdg:
        return os.path.join(os.path.expanduser(xdg), "kitty")
    return os.path.expanduser("~/.config/kitty")


def _terminal_include_line() -> str:
    return "include " + os.path.join(config_source_dir(), "terminal.conf")


def _theme_include_line(theme: str) -> str:
    return "include " + os.path.join(config_source_dir(), "look", f"{theme}.conf")


TERMINAL_SUFFIX = "/config/terminal.conf"

# Тема по умолчанию — вид, который был до появления флага: палитра
# look/ghostty.conf и её подсветка в китах. Её include уже сидит в
# terminal.conf, поэтому render_generated_conf для неё ничего не пишет.
DEFAULT_THEME = "ghostty"
THEME_ENV = "FAMILIAR_THEME"


def _available_themes() -> tuple[str, ...]:
    # Имена тем — файлы config/palette/*.conf: киты читают палитры из
    # той же директории (modules/theme.py), поэтому отдельного списка
    # тем нет, а CLI по-прежнему не импортирует пакет китов.
    palette_dir = os.path.join(config_source_dir(), "palette")
    try:
        found = sorted(os.path.splitext(f)[0] for f in os.listdir(palette_dir)
                       if f.endswith(".conf"))
    except OSError:
        return (DEFAULT_THEME,)
    return (DEFAULT_THEME,) + tuple(n for n in found if n != DEFAULT_THEME)


THEMES = _available_themes()


def wired_root(generated: str) -> str | None:
    """Корень установки, запечённый в familiar.conf — то, что kitty
    реально исполняет. Может отличаться от app_root() вызванной
    копии: клон подключён, brew стоит рядом.
    """
    for raw in generated.splitlines():
        line = raw.strip()
        if line.startswith("map "):
            for k in KITTENS.values():
                suffix = "/plugins/" + k["file"]
                if line.endswith(suffix):
                    return line[line.rindex(" ") + 1:-len(suffix)]
        elif line.startswith("include ") and line.endswith(TERMINAL_SUFFIX):
            return line[len("include "):-len(TERMINAL_SUFFIX)]
    return None


def wired_theme(generated: str) -> str:
    """Тема, запечённая в familiar.conf. Её отсутствие — DEFAULT_THEME:
    так выглядит конфиг, сгенерированный без --theme.
    """
    prefix = f"env {THEME_ENV}="
    for raw in generated.splitlines():
        line = raw.strip()
        if line.startswith(prefix):
            return line[len(prefix):].strip() or DEFAULT_THEME
    return DEFAULT_THEME


def _has_terminal_include(generated: str) -> bool:
    # По суффиксу, а не по пути вызванной копии: иначе brew-бинарь
    # сообщал бы «terminal: no» о терминал-конфиге, подключённом из
    # клона.
    return any(line.startswith("include ") and line.endswith(TERMINAL_SUFFIX)
               for line in (raw.strip() for raw in generated.splitlines()))


def _kitten_maps(name: str, plugins: str) -> list[str]:
    k = KITTENS[name]
    entry = os.path.join(plugins, k["file"])
    # goto_layout stack перед kitten: оверлей наследует размер окна,
    # под которым открыт, — в stack активное окно занимает весь таб,
    # и кит открывается во весь экран даже из сплита. Прежний layout
    # возвращает handle_result кита (modules/overlay.py). Если stack
    # не включён в enabled_layouts, kitty молча логирует ошибку и кит
    # открывается по-старому, в размер сплита.
    combine = (
        "combine @ remote_control close-window --match var:cc_plugin "
        "--ignore-no-match @ goto_layout stack @ kitten " + entry
    )
    lines = [f"# {name} — {k['desc']}"]
    for key in (k["key"], k["ru"]):
        lines.append(f"map --when-focus-on var:cc_plugin={name} cmd+shift+{key} discard_event")
        lines.append(f"map cmd+shift+{key} {combine}")
    find = k.get("find")
    if find:
        lines.append(f"# Find in Files — only inside the {name} overlay: pass the key"
                     " through to the kitten (it toggles the mode); no global mapping")
        for key in find:
            lines.append(f"map --when-focus-on var:cc_plugin={name} cmd+shift+{key}")
    return lines


def _clipboard_unmaps(names: list[str]) -> list[str]:
    active = [n for n in names if KITTENS[n]["clipboard"]]
    if not active:
        return []
    lines = ["# Inside review/log, copy (cmd+c / cmd+shift+c) and in-file search"
             " (cmd+f) go to the kitten: drop the global mappings while the"
             " overlay is focused."]
    for name in active:
        lines.append(f"map --when-focus-on var:cc_plugin={name} cmd+c")
        lines.append(f"map --when-focus-on var:cc_plugin={name} cmd+shift+c")
        # cmd+а — та же физическая клавиша f на ЙЦУКЕН: глобальный
        # cmd+f (search_scrollback) объявлен с ascii-fallback и без
        # снятия перехватил бы её
        lines.append(f"map --when-focus-on var:cc_plugin={name} cmd+f")
        lines.append(f"map --when-focus-on var:cc_plugin={name} cmd+а")
    return lines


def render_generated_conf(names: list[str], with_terminal: bool,
                          theme: str = DEFAULT_THEME) -> str:
    """Содержимое ~/.config/kitty/familiar.conf под выбранный режим."""
    ordered = [n for n in KITTENS if n in names]
    out = [
        "# Generated by `familiar enable` — do not edit by hand.",
        "# Re-running familiar rewrites this file in full.",
        "# vim:fileencoding=utf-8:ft=conf",
        "",
    ]
    if with_terminal:
        out += ["# Terminal config (look, splits, tabs, layout):",
                _terminal_include_line(), ""]
    if theme != DEFAULT_THEME:
        # Палитра терминала — только вместе с terminal.conf: без него
        # familiar не трогает внешний вид kitty. Подсветку в китах тема
        # задаёт всегда — её рисует сам kitten, читая переменную.
        if with_terminal:
            out += [f"# {theme} palette — overrides the colors from look/ghostty.conf:",
                    _theme_include_line(theme), ""]
        out += ["# Syntax highlighting theme for the kittens:",
                f"env {THEME_ENV}={theme}", ""]
    plugins = plugins_dir()
    for name in ordered:
        out += _kitten_maps(name, plugins)
        out.append("")
    clip = _clipboard_unmaps(ordered)
    if clip:
        out += clip
        out.append("")
    return "\n".join(out).rstrip() + "\n"


def upsert_managed_block(text: str, include_line: str) -> str:
    block = f"{MARKER_BEGIN}\n{include_line}\n{MARKER_END}"
    begin = text.find(MARKER_BEGIN)
    if begin == -1:
        prefix = text if text.endswith("\n") or text == "" else text + "\n"
        sep = "\n" if prefix else ""
        return f"{prefix}{sep}{block}\n"
    end = text.find(MARKER_END, begin)
    if end == -1:
        raise ValueError("kitty.conf: familiar begin marker present, end marker missing")
    end += len(MARKER_END)
    return text[:begin] + block + text[end:]


def remove_managed_block(text: str) -> tuple[str, bool]:
    begin = text.find(MARKER_BEGIN)
    if begin == -1:
        return text, False
    end = text.find(MARKER_END, begin)
    if end == -1:
        raise ValueError("kitty.conf: familiar begin marker present, end marker missing")
    end += len(MARKER_END)
    if end < len(text) and text[end] == "\n":
        end += 1
    while begin > 0 and text[begin - 1] == "\n":
        begin -= 1
    cleaned = text[:begin] + text[end:]
    if cleaned and not cleaned.endswith("\n"):
        cleaned += "\n"
    return cleaned, True


def _read(path: str) -> str:
    try:
        with open(path, encoding="utf-8") as f:
            return f.read()
    except FileNotFoundError:
        return ""


def _write(path: str, text: str) -> None:
    # Атомарно: temp-файл в том же каталоге + os.replace — упавшая
    # запись не оставит kitty.conf обрезанным.
    directory = os.path.dirname(path)
    os.makedirs(directory, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=directory, prefix=".familiar-")
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(text)
        # mkstemp даёт 0600 — сохраняем права существующего файла,
        # новому ставим обычные для конфига 0644.
        try:
            os.chmod(tmp, os.stat(path).st_mode)
        except FileNotFoundError:
            os.chmod(tmp, 0o644)
        os.replace(tmp, path)
    finally:
        if os.path.exists(tmp):
            os.remove(tmp)


def _backup_once(kitty_conf: str) -> str | None:
    # Снимаем копию только один раз — чтобы .bak хранил состояние
    # ДО familiar.
    backup = kitty_conf + BACKUP_SUFFIX
    if os.path.exists(kitty_conf) and not os.path.exists(backup):
        shutil.copy2(kitty_conf, backup)
        return backup
    return None


def _confirm(prompt: str) -> bool:
    try:
        return input(f"{prompt} [y/N] ").strip().lower() in ("y", "yes")
    except EOFError:
        return False


def _resolve_selection(args: argparse.Namespace) -> tuple[list[str], bool]:
    """Выбранные киты и флаг терминал-конфига из аргументов enable.

    `--all` — все киты + терминал; `--kittens` — все киты (+ терминал
    по флагу); имена — выбранные киты (+ терминал по флагу);
    `--terminal` без имён — режим «только терминал».
    """
    if args.all:
        return list(KITTENS), True
    if args.kittens:
        return list(KITTENS), args.terminal
    names = []
    for name in args.names:
        if name not in KITTENS:
            valid = ", ".join(KITTENS)
            raise SystemExit(f"unknown kitten: {name} (available: {valid})")
        names.append(name)
    if not names and not args.terminal:
        raise SystemExit(
            "specify kittens, --kittens, --all or --terminal (see familiar enable -h)")
    return names, args.terminal


def cmd_enable(args: argparse.Namespace) -> None:
    names, with_terminal = _resolve_selection(args)
    config_dir = kitty_config_dir()
    kitty_conf = os.path.join(config_dir, "kitty.conf")

    if with_terminal and not args.yes:
        print("familiar enable will apply the full terminal config "
              "(look, splits, tabs, layout) — it overrides your current "
              "kitty settings.")
        if not _confirm("Continue?"):
            raise SystemExit("cancelled")

    backup = _backup_once(kitty_conf)
    _write(os.path.join(config_dir, GENERATED_CONF),
           render_generated_conf(names, with_terminal, args.theme))
    _write(kitty_conf, upsert_managed_block(_read(kitty_conf),
                                            f"include {GENERATED_CONF}"))

    enabled = ", ".join(names + (["terminal"] if with_terminal else []))
    print(f"enabled: {enabled}")
    if args.theme != DEFAULT_THEME:
        print(f"theme:   {args.theme}"
              + ("" if with_terminal else " (kittens only — no --terminal)"))
    if backup:
        print(f"backup:  {backup}")
    print("reload kitty (Cmd+Ctrl+, on macOS) or restart it to apply")


def cmd_disable(args: argparse.Namespace) -> None:
    config_dir = kitty_config_dir()
    kitty_conf = os.path.join(config_dir, "kitty.conf")
    backup = kitty_conf + BACKUP_SUFFIX

    text, found = remove_managed_block(_read(kitty_conf))
    if found:
        _write(kitty_conf, text)
        generated = os.path.join(config_dir, GENERATED_CONF)
        if os.path.exists(generated):
            os.remove(generated)
        print("disabled: familiar block removed from kitty.conf")
    else:
        print("familiar is not enabled — nothing to remove")

    # --restore работает и при уже снятом блоке: откат из .bak —
    # отдельное действие, а не продолжение disable.
    restored = False
    if args.restore:
        if os.path.exists(backup):
            shutil.copy2(backup, kitty_conf)
            restored = True
            print(f"restored: kitty.conf ← {backup}")
        else:
            print(f"no backup to restore from: {backup}")
    elif found and os.path.exists(backup):
        print(f"backup available for a full revert: {backup} "
              "(familiar disable --restore)")
    if found or restored:
        print("reload kitty to apply")


def cmd_status(args: argparse.Namespace) -> None:
    config_dir = kitty_config_dir()
    kitty_conf = os.path.join(config_dir, "kitty.conf")
    text = _read(kitty_conf)
    enabled = MARKER_BEGIN in text
    generated = _read(os.path.join(config_dir, GENERATED_CONF)) if enabled else ""
    wired = wired_root(generated) if enabled else None

    print(f"version:    {VERSION}")
    print(f"config dir: {config_dir}")
    if wired:
        print(f"wired root: {wired}")
    print(f"app root:   {app_root()}")
    print(f"enabled:    {'yes' if enabled else 'no'}")
    if enabled:
        active = [n for n in KITTENS if f"cc_plugin={n} " in generated]
        print(f"kittens:    {', '.join(active) or '—'}")
        print(f"terminal:   {'yes' if _has_terminal_include(generated) else 'no'}")
        print(f"theme:      {wired_theme(generated)}")
    backup = kitty_conf + BACKUP_SUFFIX
    if os.path.exists(backup):
        print(f"backup:     {backup}")

    if os.environ.get(UPDATE_ENV, "") != "0":
        latest = latest_release()
        cur, new = parse_version(VERSION), parse_version(latest or "")
        if cur and new:
            if new > cur:
                print(f"latest:     {latest} — brew upgrade familiar")
            else:
                print("latest:     up to date")

    # realpath с обеих сторон: brew-обёртка задаёт opt-путь (симлинк
    # на Cellar), и запечённый opt-путь — та же установка, а не
    # расхождение.
    if wired and os.path.realpath(wired) != os.path.realpath(app_root()):
        print()
        print("warning: kitty.conf points at a different familiar installation")
        print("         than the one you just ran (wired root above).")
        print("         Re-run 'familiar enable …' to rebake the paths.")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="familiar",
        description="Enable/disable familiar kitty overlays in kitty.conf.")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    sub = parser.add_subparsers(dest="command", required=True)

    enable = sub.add_parser(
        "enable", help="enable kittens and/or the terminal config")
    what = enable.add_mutually_exclusive_group()
    what.add_argument("names", nargs="*", default=[], metavar="KITTEN",
                      help="which kittens: " + ", ".join(KITTENS))
    what.add_argument("--all", action="store_true",
                      help="all kittens + terminal config")
    what.add_argument("--kittens", action="store_true",
                      help="all kittens, without the terminal config")
    enable.add_argument("--terminal", action="store_true",
                        help="add the terminal config to the selection "
                             "(alone — terminal config only)")
    enable.add_argument("--theme", choices=THEMES, default=DEFAULT_THEME,
                        help="color theme: kitten syntax highlighting, plus the "
                             "terminal palette when --terminal/--all is used")
    enable.add_argument("-y", "--yes", action="store_true",
                        help="skip the terminal-config confirmation")
    enable.set_defaults(func=cmd_enable)

    disable = sub.add_parser("disable", help="remove the familiar block from kitty.conf")
    disable.add_argument("--restore", action="store_true",
                         help="restore kitty.conf from the backup")
    disable.set_defaults(func=cmd_disable)

    status = sub.add_parser("status", help="show what is enabled")
    status.set_defaults(func=cmd_status)
    return parser


def main(argv: list[str] | None = None) -> None:
    args = build_parser().parse_args(argv)
    args.func(args)


if __name__ == "__main__":
    try:
        main()
    except (OSError, ValueError) as exc:
        print(f"familiar: {exc}", file=sys.stderr)
        sys.exit(1)
